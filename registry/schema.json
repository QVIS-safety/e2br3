{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "E2BR3 Field Registry Row",
  "type": "object",
  "required": [
    "id",
    "e2br3_code",
    "label",
    "section",
    "authority",
    "status",
    "backend",
    "frontend"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "e2br3_code": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "section": {
      "type": "string",
      "enum": ["N", "C", "D", "E", "F", "G", "H"]
    },
    "authority": {
      "type": "string",
      "enum": ["ICH", "FDA", "MFDS"]
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "backend_missing",
        "frontend_missing",
        "intentionally_unmapped",
        "not_applicable",
        "conflict"
      ]
    },
    "backend": { "$ref": "#/$defs/mapping" },
    "frontend": { "$ref": "#/$defs/mapping" },
    "evidence": { "type": "string" },
    "action": { "type": "string" },
    "notes": { "type": "string" },
    "local_only": { "type": "boolean" }
  },
  "$defs": {
    "mappingStatus": {
      "type": "string",
      "enum": ["mapped", "missing", "not_applicable", "conflict"]
    },
    "mapping": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "$ref": "#/$defs/mappingStatus" },
        "model": { "type": "string" },
        "field": { "type": "string" },
        "section": { "type": "string" },
        "file": { "type": "string" },
        "evidence": { "type": "string" }
      }
    }
  }
}
